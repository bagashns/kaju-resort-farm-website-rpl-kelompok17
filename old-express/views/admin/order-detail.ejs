<%- include('../partials/header') %>

<%
  let statusColor = 'gray', statusText = order.status;
  if (order.status === 'menunggu_pembayaran') { statusColor = 'yellow'; statusText = 'Menunggu Pembayaran'; }
  else if (order.status === 'menunggu_verifikasi') { statusColor = 'blue'; statusText = 'Menunggu Verifikasi'; }
  else if (order.status === 'lunas') { statusColor = 'green'; statusText = 'Lunas'; }
  else if (order.status === 'diproses') { statusColor = 'indigo'; statusText = 'Diproses'; }
  else if (order.status === 'dikirim') { statusColor = 'purple'; statusText = 'Dikirim'; }
  else if (order.status === 'selesai') { statusColor = 'green'; statusText = 'Selesai'; }
  else if (order.status === 'ditolak') { statusColor = 'red'; statusText = 'Ditolak'; }
%>

<div class="max-w-4xl mx-auto px-4 py-8">
  <a href="/admin/pesanan" class="text-green-600 hover:text-green-800 mb-4 inline-block"><i class="fas fa-arrow-left mr-1"></i> Kembali</a>

  <div class="grid md:grid-cols-2 gap-6 mb-6">
    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="font-bold text-lg text-gray-800 mb-4">Detail Pesanan</h2>
      <table class="w-full text-sm">
        <tr><td class="py-2 text-gray-500">Invoice</td><td class="py-2 font-mono font-semibold"><%= order.invoice_number %></td></tr>
        <tr><td class="py-2 text-gray-500">Tanggal</td><td class="py-2"><%= new Date(order.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td></tr>
        <tr><td class="py-2 text-gray-500">Status</td><td class="py-2"><span class="bg-<%= statusColor %>-100 text-<%= statusColor %>-700 px-3 py-1 rounded-full text-sm"><%= statusText %></span></td></tr>
        <tr><td class="py-2 text-gray-500">Total</td><td class="py-2 text-green-700 font-bold text-lg"><%= formatRupiah(order.total_amount) %></td></tr>
      </table>
    </div>
    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="font-bold text-lg text-gray-800 mb-4">Data Pelanggan</h2>
      <table class="w-full text-sm">
        <tr><td class="py-2 text-gray-500">Nama</td><td class="py-2 font-semibold"><%= order.customer_name %></td></tr>
        <tr><td class="py-2 text-gray-500">Email</td><td class="py-2"><%= order.customer_email %></td></tr>
        <tr><td class="py-2 text-gray-500">Telepon</td><td class="py-2"><%= order.customer_phone %></td></tr>
        <tr><td class="py-2 text-gray-500">Alamat</td><td class="py-2"><%= order.shipping_address %></td></tr>
      </table>
      <a href="https://wa.me/<%= order.customer_phone.replace(/[^0-9]/g, '').replace(/^0/, '62') %>?text=Halo <%= order.customer_name %>, terkait pesanan <%= order.invoice_number %>" target="_blank" class="mt-3 inline-flex items-center gap-1 bg-green-500 hover:bg-green-600 text-white text-sm px-4 py-2 rounded-lg transition">
        <i class="fab fa-whatsapp"></i> WhatsApp
      </a>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-md p-6 mb-6">
    <h2 class="font-bold text-lg text-gray-800 mb-4">Item Pesanan</h2>
    <% items.forEach(item => { %>
      <div class="flex justify-between items-center border-b py-3">
        <div>
          <p class="font-semibold"><%= item.product_name %></p>
          <p class="text-sm text-gray-500"><%= item.product_category %> - <%= item.product_weight %> Kg</p>
        </div>
        <span class="font-bold text-green-700"><%= formatRupiah(item.price) %></span>
      </div>
    <% }) %>
    <div class="flex justify-between items-center font-bold text-xl pt-4">
      <span>Total</span><span class="text-green-700"><%= formatRupiah(order.total_amount) %></span>
    </div>
  </div>

  <% if (order.payment_proof) { %>
    <div class="bg-white rounded-xl shadow-md p-6 mb-6">
      <h2 class="font-bold text-lg text-gray-800 mb-4">Bukti Pembayaran</h2>
      <img src="<%= order.payment_proof %>" alt="Bukti Pembayaran" class="max-w-md rounded-lg shadow">
    </div>
  <% } %>

  <% if (order.notes) { %>
    <div class="bg-white rounded-xl shadow-md p-6 mb-6">
      <h2 class="font-bold text-lg text-gray-800 mb-2">Catatan Pembeli</h2>
      <p class="text-gray-600"><%= order.notes %></p>
    </div>
  <% } %>

  <div class="bg-white rounded-xl shadow-md p-6">
    <h2 class="font-bold text-lg text-gray-800 mb-4">Update Status Pesanan</h2>
    <form id="update-status-form" action="/admin/pesanan/<%= order.id %>/status" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
        <select name="status" class="w-full border rounded-lg px-3 py-2">
          <option value="menunggu_pembayaran" <%= order.status === 'menunggu_pembayaran' ? 'selected' : '' %>>Menunggu Pembayaran</option>
          <option value="menunggu_verifikasi" <%= order.status === 'menunggu_verifikasi' ? 'selected' : '' %>>Menunggu Verifikasi</option>
          <option value="lunas" <%= order.status === 'lunas' ? 'selected' : '' %>>Lunas</option>
          <option value="diproses" <%= order.status === 'diproses' ? 'selected' : '' %>>Diproses</option>
          <option value="dikirim" <%= order.status === 'dikirim' ? 'selected' : '' %>>Dikirim/Siap Jemput</option>
          <option value="selesai" <%= order.status === 'selesai' ? 'selected' : '' %>>Selesai</option>
          <option value="ditolak" <%= order.status === 'ditolak' ? 'selected' : '' %>>Ditolak</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Catatan Admin</label>
        <textarea name="admin_notes" rows="3" class="w-full border rounded-lg px-3 py-2" placeholder="Catatan untuk pembeli..."><%= order.admin_notes || '' %></textarea>
      </div>
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition">
        <i class="fas fa-save mr-2"></i>Update Status
      </button>
    </form>
  </div>
</div>

<script>
  document.getElementById('update-status-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const form = this;
    const data = new FormData(form);
    fetch(form.action, {
      method: 'POST',
      body: new URLSearchParams(data),
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      redirect: 'manual'
    }).then(function() {
      window.location.href = '/admin/pesanan';
    }).catch(function() {
      window.location.href = '/admin/pesanan';
    });
  });
</script>

<%- include('../partials/footer') %>
