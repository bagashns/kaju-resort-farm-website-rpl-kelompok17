<%- include('partials/header') %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <nav class="text-sm text-gray-500 mb-6">
    <a href="/" class="hover:text-green-600">Beranda</a> &raquo;
    <a href="/katalog" class="hover:text-green-600">Katalog</a> &raquo;
    <span class="text-gray-800"><%= product.name %></span>
  </nav>

  <div class="grid md:grid-cols-2 gap-8">
    <div class="bg-white rounded-2xl shadow-lg">
      <img src="<%= product.image || '/images/default-product.jpg' %>" alt="<%= product.name %>" class="w-full rounded-2xl" onerror="this.src='/images/default-product.jpg'">
    </div>

    <div>
      <span class="inline-block bg-green-100 text-green-700 text-sm px-3 py-1 rounded-full mb-3"><%= product.category_name %></span>
      <h1 class="text-3xl font-bold text-gray-800 mb-4"><%= product.name %></h1>
      <div class="text-3xl font-extrabold text-green-700 mb-6"><%= formatRupiah(product.price) %></div>

      <div class="bg-gray-50 rounded-xl p-5 mb-6">
        <h3 class="font-semibold text-gray-700 mb-3">Spesifikasi</h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="flex items-center space-x-2">
            <i class="fas fa-weight-hanging text-green-500"></i>
            <div><span class="text-gray-500 text-sm">Bobot</span><br><strong><%= product.weight %> Kg</strong></div>
          </div>
          <div class="flex items-center space-x-2">
            <i class="fas fa-clock text-green-500"></i>
            <div><span class="text-gray-500 text-sm">Usia</span><br><strong><%= product.age %></strong></div>
          </div>
          <div class="flex items-center space-x-2">
            <i class="fas fa-venus-mars text-green-500"></i>
            <div><span class="text-gray-500 text-sm">Jenis Kelamin</span><br><strong><%= product.gender %></strong></div>
          </div>
          <div class="flex items-center space-x-2">
            <i class="fas fa-heartbeat text-green-500"></i>
            <div><span class="text-gray-500 text-sm">Kesehatan</span><br><strong><%= product.health_status %></strong></div>
          </div>
        </div>
      </div>

      <% if (product.description) { %>
        <div class="mb-6">
          <h3 class="font-semibold text-gray-700 mb-2">Deskripsi</h3>
          <p class="text-gray-600 leading-relaxed"><%= product.description %></p>
        </div>
      <% } %>

      <% if (product.status === 'tersedia') { %>
        <div class="flex gap-3">
          <% if (user && user.role === 'customer') { %>
            <form action="/keranjang/tambah/<%= product.id %>" method="POST" class="flex-1">
              <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition">
                <i class="fas fa-cart-plus mr-2"></i>Masukkan Keranjang
              </button>
            </form>
          <% } else if (!user) { %>
            <a href="/login" class="flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition text-center">
              <i class="fas fa-sign-in-alt mr-2"></i>Login untuk Membeli
            </a>
          <% } %>
          <a href="https://wa.me/6282114370112?text=Halo, saya tertarik dengan <%= encodeURIComponent(product.name) %> di Kaju Resort Farm" target="_blank" class="bg-green-500 hover:bg-green-400 text-white px-6 py-3 rounded-xl transition">
            <i class="fab fa-whatsapp text-xl"></i>
          </a>
        </div>
      <% } else { %>
        <div class="bg-red-50 border border-red-200 text-red-700 py-3 px-4 rounded-xl text-center">
          <i class="fas fa-times-circle mr-2"></i>Produk ini sudah <%= product.status === 'dipesan' ? 'dipesan' : 'terjual' %>
        </div>
      <% } %>
    </div>
  </div>

  <% if (related.length > 0) { %>
  <section class="mt-12">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Ternak Serupa</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <% related.forEach(p => { %>
        <a href="/katalog/<%= p.id %>" class="bg-white rounded-xl shadow-md hover:shadow-xl transition overflow-hidden group">
          <div class="h-40 overflow-hidden">
            <img src="<%= p.image || '/images/default-product.jpg' %>" alt="<%= p.name %>" class="w-full h-full object-cover group-hover:scale-105 transition" onerror="this.src='/images/default-product.jpg'">
          </div>
          <div class="p-4">
            <h4 class="font-semibold text-gray-800"><%= p.name %></h4>
            <p class="text-green-700 font-bold mt-1"><%= formatRupiah(p.price) %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</div>

<%- include('partials/footer') %>
