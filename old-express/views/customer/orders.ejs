<%- include('../partials/header') %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="mb-8 border-b border-slate-200 pb-4">
    <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-3">
      <div class="bg-brand-100 text-brand-600 p-2 rounded-lg">
        <i class="fas fa-clipboard-list"></i>
      </div>
      Riwayat Pesanan
    </h1>
    <p class="text-slate-500 text-sm mt-1 ml-12">Lacak status pesanan dan transaksi Anda.</p>
  </div>

  <% if (orders.length === 0) { %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-16 text-center">
      <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-5 text-slate-300">
        <i class="fas fa-clipboard-list text-4xl"></i>
      </div>
      <h3 class="text-xl font-bold text-slate-800 mb-2">Belum ada pesanan</h3>
      <p class="text-slate-500 text-sm mb-6">Anda belum melakukan pembelian apapun. Mari mulai berbelanja.</p>
      <a href="/katalog" class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-2.5 rounded-xl transition-colors inline-flex items-center gap-2 shadow-sm font-medium text-sm">
        <i class="fas fa-shopping-bag"></i> Mulai Belanja
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% orders.forEach(order => { %>
        <%
          let statusColor = 'slate';
          let statusText = order.status.replace(/_/g, ' ');
          if (order.status === 'menunggu_pembayaran') { statusColor = 'amber'; statusText = 'Menunggu Pembayaran'; }
          else if (order.status === 'menunggu_verifikasi') { statusColor = 'blue'; statusText = 'Menunggu Verifikasi'; }
          else if (order.status === 'lunas') { statusColor = 'emerald'; statusText = 'Lunas'; }
          else if (order.status === 'diproses') { statusColor = 'indigo'; statusText = 'Diproses'; }
          else if (order.status === 'dikirim') { statusColor = 'purple'; statusText = 'Dikirim'; }
          else if (order.status === 'selesai') { statusColor = 'brand'; statusText = 'Selesai'; }
          else if (order.status === 'ditolak') { statusColor = 'rose'; statusText = 'Ditolak'; }
        %>
        <a href="/pesanan/<%= order.id %>" class="block bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:border-brand-200 transition-all p-5 group relative overflow-hidden">
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-<%= statusColor %>-500"></div>
          <div class="flex flex-col md:flex-row justify-between md:items-center gap-4 pl-3">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-semibold text-slate-500 bg-slate-100 px-2.5 py-1 rounded-md"><%= order.invoice_number %></span>
                <span class="text-xs text-slate-400"><i class="far fa-calendar-alt mr-1"></i><%= new Date(order.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
              </div>
              <h3 class="font-bold text-slate-800 text-lg group-hover:text-brand-600 transition-colors"><%= order.item_count %> Ternak Dipesan</h3>
            </div>
            <div class="flex flex-row md:flex-col items-center md:items-end justify-between md:justify-center gap-2">
              <span class="inline-block bg-<%= statusColor %>-50 text-<%= statusColor %>-600 border border-<%= statusColor %>-200 text-xs px-3 py-1.5 rounded-full font-bold uppercase tracking-wider">
                <%= statusText %>
              </span>
              <p class="text-slate-800 font-black text-lg"><%= formatRupiah(order.total_amount) %></p>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
