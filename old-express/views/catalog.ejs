<%- include('partials/header') %>
<% const title = 'Katalog Ternak' %>

<section class="relative bg-brand-950 text-white pt-16 pb-10 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-[-20%] left-[-10%] w-[40%] h-[60%] bg-brand-600 rounded-full blur-[80px] opacity-30 mix-blend-screen animate-float"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <h1 class="text-3xl md:text-4xl font-black mb-3 tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white to-brand-200">Katalog Ternak Premium</h1>
    <p class="text-brand-100 text-base font-light max-w-2xl">Jelajahi dan temukan hewan ternak berkualitas tinggi untuk memenuhi standar terbaik peternakan atau bisnis Anda.</p>
  </div>
</section>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-10 relative z-20 -mt-16">
    <form action="/katalog" method="GET" class="grid grid-cols-1 md:grid-cols-5 gap-6 items-end">
      <div class="md:col-span-1">
        <label class="block text-slate-500 font-medium text-sm mb-2">Pencarian</label>
        <div class="relative">
          <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
          <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Cari ternak..." class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-11 pr-4 py-3 text-slate-700 focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all">
        </div>
      </div>
      <div>
        <label class="block text-slate-500 font-medium text-sm mb-2">Kategori</label>
        <div class="relative">
          <select name="kategori" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-700 appearance-none focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all">
            <option value="semua">Semua Kategori</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.id %>" <%= filters.kategori == c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
          <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-sm"></i>
        </div>
      </div>
      <div>
        <label class="block text-slate-500 font-medium text-sm mb-2">Harga Minimum</label>
        <div class="relative">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-medium">Rp</span>
          <input type="number" name="min_harga" value="<%= filters.min_harga || '' %>" placeholder="0" class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-10 pr-4 py-3 text-slate-700 focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all">
        </div>
      </div>
      <div>
        <label class="block text-slate-500 font-medium text-sm mb-2">Urutkan Berdasarkan</label>
        <div class="relative">
          <select name="sort" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-700 appearance-none focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all">
            <option value="terbaru" <%= filters.sort === 'terbaru' ? 'selected' : '' %>>Paling Baru</option>
            <option value="harga_asc" <%= filters.sort === 'harga_asc' ? 'selected' : '' %>>Harga Terendah</option>
            <option value="harga_desc" <%= filters.sort === 'harga_desc' ? 'selected' : '' %>>Harga Tertinggi</option>
            <option value="bobot_desc" <%= filters.sort === 'bobot_desc' ? 'selected' : '' %>>Bobot Terberat</option>
          </select>
          <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-sm"></i>
        </div>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white font-medium px-4 py-3 rounded-xl transition-colors shadow-md shadow-brand-500/20 flex-1 flex justify-center items-center gap-2 text-sm">
          <i class="fas fa-filter"></i> Terapkan
        </button>
        <a href="/katalog" class="bg-slate-100 hover:bg-slate-200 text-slate-600 px-4 py-3 rounded-xl transition-colors flex items-center justify-center">
          <i class="fas fa-redo-alt"></i>
        </a>
      </div>
    </form>
  </div>

  <div class="flex items-center gap-3 mb-6">
    <div class="h-px bg-slate-200 flex-1"></div>
    <p class="text-slate-500 font-medium text-xs bg-slate-50 px-3 py-1 rounded-full border border-slate-200"><span class="text-brand-600 font-bold"><%= products.length %></span> Ternak Ditemukan</p>
    <div class="h-px bg-slate-200 flex-1"></div>
  </div>

  <% if (products.length === 0) { %>
    <div class="text-center py-16 bg-slate-50/50 rounded-2xl border border-slate-100 border-dashed">
      <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm border border-slate-100 text-slate-300">
        <i class="fas fa-search text-2xl"></i>
      </div>
      <h3 class="text-xl font-bold text-slate-700 mb-2">Ternak Tidak Ditemukan</h3>
      <p class="text-slate-500 max-w-md mx-auto text-sm">Kami tidak dapat menemukan ternak yang sesuai dengan kriteria filter Anda. Coba sesuaikan ulang pengaturan pencarian.</p>
      <a href="/katalog" class="inline-flex items-center gap-2 mt-6 text-brand-600 font-medium hover:text-brand-700 hover:underline text-sm">
        <i class="fas fa-redo-alt"></i> Reset Filter
      </a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% products.forEach(p => { %>
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 border border-slate-100 overflow-hidden flex flex-col">
          <div class="relative h-48 overflow-hidden bg-slate-100">
            <img src="<%= p.image || '/images/default-product.jpg' %>" alt="<%= p.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out" onerror="this.src='/images/default-product.jpg'">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <div class="absolute top-4 left-4 flex flex-col gap-2">
              <span class="bg-white/90 backdrop-blur-sm text-brand-700 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm w-fit">
                <%= p.category_name %>
              </span>
              <% if (p.health_status === 'Sehat') { %>
                <span class="bg-blue-500/90 backdrop-blur-sm text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-sm flex items-center gap-1.5 w-fit">
                  <i class="fas fa-check-circle"></i> Sehat
                </span>
              <% } %>
            </div>
            
            <div class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 z-10 delay-100">
              <span class="bg-white/20 backdrop-blur-md text-white border border-white/30 text-xs px-2.5 py-1 rounded-lg flex items-center gap-1.5"><i class="fas fa-weight-hanging"></i><%= p.weight %> Kg</span>
              <span class="bg-white/20 backdrop-blur-md text-white border border-white/30 text-xs px-2.5 py-1 rounded-lg flex items-center gap-1.5"><i class="fas fa-clock"></i><%= p.age %></span>
            </div>
          </div>
          <div class="p-4 flex flex-col flex-grow">
            <h3 class="font-bold text-lg text-slate-800 mb-3 group-hover:text-brand-600 transition-colors line-clamp-1"><%= p.name %></h3>
            
            <div class="mt-auto flex items-center justify-between pt-3 border-t border-slate-100">
              <div>
                <span class="text-brand-600 font-bold text-lg"><%= formatRupiah(p.price) %></span>
              </div>
              <a href="/katalog/<%= p.id %>" class="w-8 h-8 bg-slate-50 text-slate-600 rounded-full flex items-center justify-center group-hover:bg-brand-500 group-hover:text-white transition-colors text-xs">
                <i class="fas fa-arrow-right -rotate-45 group-hover:rotate-0 transition-transform"></i>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
