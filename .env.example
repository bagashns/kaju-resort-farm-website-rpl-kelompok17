# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# cp .env.example .env

# ── Supabase ──────────────────────────────────────────────
# Dapatkan dari: https://app.supabase.com/ → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ── Midtrans (Payment Gateway) ────────────────────────────
# Dapatkan dari: https://dashboard.midtrans.com/ → Settings → Access Keys
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ── Session ───────────────────────────────────────────────
# Ganti dengan string acak yang panjang dan aman
SESSION_SECRET=ganti-dengan-string-rahasia-yang-panjang
