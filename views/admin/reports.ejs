<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-800 mb-6"><i class="fas fa-chart-bar mr-2 text-green-600"></i>Laporan Penjualan</h1>

  <div class="flex flex-wrap gap-2 mb-6">
    <% ['semua', 'hari', 'minggu', 'bulan'].forEach(p => { %>
      <a href="/admin/laporan?period=<%= p %>" class="px-4 py-2 rounded-full text-sm transition <%= period === p ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %>">
        <%= p === 'semua' ? 'Semua Waktu' : p === 'hari' ? 'Hari Ini' : p === 'minggu' ? '7 Hari Terakhir' : '30 Hari Terakhir' %>
      </a>
    <% }) %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
      <p class="text-gray-500 text-sm">Total Pendapatan</p>
      <p class="text-2xl font-bold text-green-700"><%= formatRupiah(summary.total_revenue) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500">
      <p class="text-gray-500 text-sm">Total Pesanan</p>
      <p class="text-3xl font-bold text-gray-800"><%= summary.total_orders %></p>
    </div>
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
      <p class="text-gray-500 text-sm">Pesanan Selesai</p>
      <p class="text-3xl font-bold text-green-700"><%= summary.completed_orders %></p>
    </div>
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-red-500">
      <p class="text-gray-500 text-sm">Pesanan Ditolak</p>
      <p class="text-3xl font-bold text-red-600"><%= summary.rejected_orders %></p>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="text-xl font-bold text-gray-800 mb-4">Penjualan per Kategori</h2>
      <% if (salesByCategory.length === 0) { %>
        <p class="text-gray-500 text-center py-8">Belum ada data penjualan</p>
      <% } else { %>
        <div class="space-y-4">
          <% const maxRev = Math.max(...salesByCategory.map(s => s.revenue)); %>
          <% salesByCategory.forEach(s => { %>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="font-semibold text-gray-700"><%= s.category %></span>
                <span class="text-gray-500"><%= s.count %> terjual - <%= formatRupiah(s.revenue) %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-3">
                <div class="bg-green-600 h-3 rounded-full" style="width: <%= (s.revenue / maxRev * 100) %>%"></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="text-xl font-bold text-gray-800 mb-4">Penjualan Harian</h2>
      <% if (dailySales.length === 0) { %>
        <p class="text-gray-500 text-center py-8">Belum ada data</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead><tr class="border-b text-left text-gray-500"><th class="py-2">Tanggal</th><th class="py-2">Pesanan</th><th class="py-2">Pendapatan</th></tr></thead>
            <tbody>
              <% dailySales.forEach(d => { %>
                <tr class="border-b"><td class="py-2"><%= d.date %></td><td class="py-2"><%= d.orders %></td><td class="py-2 font-semibold"><%= formatRupiah(d.revenue) %></td></tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
