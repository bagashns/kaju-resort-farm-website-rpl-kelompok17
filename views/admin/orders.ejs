<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-800 mb-6"><i class="fas fa-shopping-bag mr-2 text-green-600"></i>Manajemen Pesanan</h1>

  <div class="flex flex-wrap gap-2 mb-6">
    <% const statuses = [
      { val: 'semua', label: 'Semua' },
      { val: 'menunggu_pembayaran', label: 'Menunggu Pembayaran' },
      { val: 'menunggu_verifikasi', label: 'Menunggu Verifikasi' },
      { val: 'lunas', label: 'Lunas' },
      { val: 'diproses', label: 'Diproses' },
      { val: 'dikirim', label: 'Dikirim' },
      { val: 'selesai', label: 'Selesai' },
      { val: 'ditolak', label: 'Ditolak' }
    ]; %>
    <% statuses.forEach(s => { %>
      <a href="/admin/pesanan?status=<%= s.val %>" class="px-4 py-2 rounded-full text-sm transition <%= filterStatus === s.val ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %>"><%= s.label %></a>
    <% }) %>
  </div>

  <% if (orders.length === 0) { %>
    <div class="bg-white rounded-xl shadow-md p-12 text-center">
      <p class="text-gray-500">Tidak ada pesanan untuk ditampilkan.</p>
    </div>
  <% } else { %>
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="bg-gray-50 text-left text-gray-600">
            <th class="py-3 px-4">Invoice</th><th class="py-3 px-4">Pelanggan</th><th class="py-3 px-4">Telepon</th>
            <th class="py-3 px-4">Item</th><th class="py-3 px-4">Total</th><th class="py-3 px-4">Status</th><th class="py-3 px-4">Tanggal</th><th class="py-3 px-4"></th>
          </tr></thead>
          <tbody>
            <% orders.forEach(o => { %>
              <%
                let sc = 'gray';
                if (o.status === 'menunggu_pembayaran') sc = 'yellow';
                else if (o.status === 'menunggu_verifikasi') sc = 'blue';
                else if (o.status === 'lunas' || o.status === 'selesai') sc = 'green';
                else if (o.status === 'ditolak') sc = 'red';
                else if (o.status === 'diproses' || o.status === 'dikirim') sc = 'indigo';
              %>
              <tr class="border-b hover:bg-gray-50">
                <td class="py-3 px-4 font-mono text-xs"><%= o.invoice_number %></td>
                <td class="py-3 px-4 font-semibold"><%= o.customer_name %></td>
                <td class="py-3 px-4"><%= o.customer_phone %></td>
                <td class="py-3 px-4"><%= o.item_count %></td>
                <td class="py-3 px-4 font-semibold"><%= formatRupiah(o.total_amount) %></td>
                <td class="py-3 px-4"><span class="bg-<%= sc %>-100 text-<%= sc %>-700 text-xs px-2 py-1 rounded-full"><%= o.status.replace(/_/g, ' ') %></span></td>
                <td class="py-3 px-4 text-xs text-gray-500"><%= new Date(o.created_at).toLocaleDateString('id-ID') %></td>
                <td class="py-3 px-4"><a href="/admin/pesanan/<%= o.id %>" class="bg-green-100 hover:bg-green-200 text-green-700 px-3 py-1 rounded text-xs transition">Detail</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
