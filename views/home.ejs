<%- include('partials/header') %>

<section class="relative bg-brand-950 text-white overflow-hidden min-h-[400px] flex items-center pt-16 pb-20">
  <!-- Gradient Mesh Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-brand-600 rounded-full blur-[100px] opacity-40 mix-blend-screen animate-float"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-emerald-500 rounded-full blur-[100px] opacity-30 mix-blend-screen animate-pulse-soft"></div>
    <div class="absolute top-[20%] right-[10%] w-[30%] h-[30%] bg-teal-400 rounded-full blur-[80px] opacity-20 mix-blend-screen animate-float" style="animation-delay: 2s;"></div>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-6">
          <span class="flex h-2 w-2 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span class="text-emerald-100 text-xs font-medium tracking-wide">Peternakan Premium Terpercaya</span>
        </div>
        
        <h1 class="text-4xl lg:text-5xl font-black leading-tight mb-4 tracking-tight text-white">
          Kualitas Terbaik <br />
          <span class="text-white">Untuk Anda</span>
        </h1>
        
        <p class="text-slate-300 text-base mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed font-light">
          Platform peternakan digital pertama yang memberikan transparansi harga, kepastian kualitas, dan kemudahan dalam setiap transaksi Anda.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
          <a href="/katalog" class="group relative inline-flex items-center justify-center gap-2 bg-brand-500 hover:bg-brand-400 text-white font-semibold px-6 py-3 rounded-full transition-all duration-300 shadow-[0_0_20px_-5px_rgba(59,166,116,0.5)] hover:-translate-y-0.5 text-sm">
            <i class="fas fa-search"></i>
            <span>Jelajahi Katalog</span>
            <i class="fas fa-arrow-right opacity-0 -ml-4 group-hover:opacity-100 group-hover:ml-0 transition-all duration-300"></i>
          </a>
          <a href="https://wa.me/62895349275679" target="_blank" class="inline-flex items-center justify-center gap-2 bg-white/5 hover:bg-white/10 text-white border border-white/10 font-semibold px-6 py-3 rounded-full transition-all duration-300 backdrop-blur-sm hover:-translate-y-0.5 text-sm">
            <i class="fab fa-whatsapp text-emerald-400 text-base"></i>
            <span>Konsultasi</span>
          </a>
        </div>
      </div>
      
      <div class="hidden lg:flex justify-center relative">
        <div class="relative w-full max-w-sm aspect-square">
          <div class="absolute inset-0 bg-brand-500/20 rounded-full blur-2xl animate-pulse-soft"></div>
          <div class="glass-dark absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-48 h-48 rounded-full flex flex-col items-center justify-center shadow-xl border border-white/10 z-20 hover:scale-105 transition-transform duration-500">
            <div class="bg-gradient-to-br from-emerald-400 to-brand-500 bg-clip-text text-transparent mb-1">
              <i class="fas fa-award text-4xl"></i>
            </div>
            <p class="text-2xl font-black text-white"><%= stats.totalProducts %></p>
            <p class="text-brand-200 font-medium tracking-wide text-xs uppercase">Ternak Premium</p>
          </div>
          <!-- Decorative Floating Cards -->
          <div class="glass-dark absolute top-10 right-4 p-3 rounded-xl animate-float shadow-lg border border-white/10 z-20">
            <div class="flex items-center gap-3">
              <div class="bg-emerald-500/20 p-2 rounded-lg text-emerald-400"><i class="fas fa-certificate"></i></div>
              <div>
                <p class="text-white font-bold text-sm">Tersertifikasi</p>
                <p class="text-slate-400 text-xs">Sehat & Aman</p>
              </div>
            </div>
          </div>
          <div class="glass-dark absolute bottom-10 left-4 p-3 rounded-xl animate-float shadow-lg border border-white/10 z-20" style="animation-delay: 1.5s;">
            <div class="flex items-center gap-2">
              <div class="bg-blue-500/20 p-1.5 rounded-md text-blue-400"><i class="fas fa-truck-fast text-sm"></i></div>
              <div>
                <p class="text-white font-bold text-xs">Pengiriman</p>
                <p class="text-slate-400 text-[10px]">Cepat & Aman</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-20">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white/90 backdrop-blur-lg rounded-2xl shadow-sm border border-slate-100 p-5 flex items-center space-x-4 hover:-translate-y-1 transition-transform duration-300 group">
      <div class="bg-brand-50 p-3 rounded-xl text-brand-600 group-hover:scale-105 transition-all">
        <i class="fas fa-shield-alt text-xl"></i>
      </div>
      <div>
        <h3 class="font-bold text-slate-800 text-base mb-0.5">Kualitas Terjamin</h3>
        <p class="text-slate-500 text-sm">Ternak sehat bersertifikasi standar. Terjamin bebas penyakit.</p>
      </div>
    </div>
    <div class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-sm border border-white p-5 flex items-center space-x-4 hover:-translate-y-1 transition-transform duration-300 group">
      <div class="bg-amber-50 p-3 rounded-xl text-amber-600 group-hover:scale-105 transition-all">
        <i class="fas fa-tags text-xl"></i>
      </div>
      <div>
        <h3 class="font-bold text-slate-800 text-base mb-0.5">Harga Transparan</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Sistem harga jujur tanpa biaya tersembunyi. Bayar sesuai kualitas.</p>
      </div>
    </div>
    <div class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-sm border border-white p-5 flex items-center space-x-4 hover:-translate-y-1 transition-transform duration-300 group">
      <div class="bg-blue-50 p-3 rounded-xl text-blue-600 group-hover:scale-105 transition-all">
        <i class="fas fa-truck text-xl"></i>
      </div>
      <div>
        <h3 class="font-bold text-slate-800 text-base mb-0.5">Pengiriman Aman</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Armada khusus untuk memastikan ternak tiba dalam kondisi prima.</p>
      </div>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="text-center mb-10 max-w-xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-black text-slate-800 tracking-tight mb-2">Kategori Pilihan</h2>
    <p class="text-slate-500 text-sm">Temukan hewan ternak terbaik sesuai dengan kebutuhan Anda.</p>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-<%= categories.length > 4 ? 4 : categories.length %> gap-4">
    <% categories.forEach(cat => { %>
      <a href="/katalog?kategori=<%= cat.id %>" class="group relative bg-white rounded-2xl p-5 text-center hover:shadow-md transition-all duration-300 border border-slate-100 hover:border-brand-200">
        <div class="w-12 h-12 mx-auto bg-slate-50 group-hover:bg-brand-50 text-brand-600 rounded-xl flex items-center justify-center mb-3 transition-colors duration-300">
          <i class="<%= cat.icon || 'fas fa-paw' %> text-2xl"></i>
        </div>
        <h3 class="font-bold text-base text-slate-800 mb-1 group-hover:text-brand-600 transition-colors"><%= cat.name %></h3>
        <p class="text-slate-500 text-xs hidden sm:block"><%= cat.description || 'Pilihan ternak unggul' %></p>
      </a>
    <% }) %>
  </div>
</section>

<% if (featured.length > 0) { %>
<section class="py-16 bg-slate-50 border-y border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row justify-between items-end mb-8 gap-4">
      <div>
        <h2 class="text-2xl md:text-3xl font-black text-slate-800 tracking-tight mb-1">Koleksi Terbaru</h2>
        <p class="text-slate-500 text-sm">Pilihan ternak premium yang baru saja tiba.</p>
      </div>
      <a href="/katalog" class="group flex items-center gap-1.5 text-brand-600 text-sm font-semibold hover:text-brand-700 transition-colors">
        <span>Lihat Semua</span>
        <i class="fas fa-arrow-right transform group-hover:translate-x-1 transition-transform"></i>
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% featured.forEach(p => { %>
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 border border-slate-100 overflow-hidden flex flex-col">
          <div class="relative h-48 overflow-hidden bg-slate-100">
            <img src="<%= p.image || '/images/default-product.jpg' %>" alt="<%= p.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out" onerror="this.src='/images/default-product.jpg'">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute top-4 left-4">
              <span class="bg-white/90 backdrop-blur-sm text-brand-700 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">
                <%= p.category_name %>
              </span>
            </div>
            <div class="absolute bottom-4 left-4 right-4 flex gap-2 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 z-10 delay-100">
              <span class="bg-white/20 backdrop-blur-md text-white border border-white/30 text-xs px-2.5 py-1 rounded-lg flex items-center gap-1.5"><i class="fas fa-weight-hanging"></i><%= p.weight %> Kg</span>
              <span class="bg-white/20 backdrop-blur-md text-white border border-white/30 text-xs px-2.5 py-1 rounded-lg flex items-center gap-1.5"><i class="fas fa-clock"></i><%= p.age %></span>
            </div>
          </div>
          <div class="p-4 flex flex-col flex-grow">
            <h3 class="font-bold text-lg text-slate-800 mb-3 group-hover:text-brand-600 transition-colors line-clamp-1"><%= p.name %></h3>
            
            <div class="mt-auto flex items-center justify-between pt-3 border-t border-slate-100">
              <div>
                <span class="text-brand-600 font-bold text-lg"><%= formatRupiah(p.price) %></span>
              </div>
              <a href="/katalog/<%= p.id %>" class="w-8 h-8 bg-slate-50 text-slate-600 rounded-full flex items-center justify-center group-hover:bg-brand-500 group-hover:text-white transition-colors text-xs">
                <i class="fas fa-arrow-right -rotate-45 group-hover:rotate-0 transition-transform"></i>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>
